# Your deployer/attacker private key (no 0x prefix)
PRIVATE_KEY=

# ── Token address (onTransfer hook required for reentrancy demo) ───────────────
# Placeholder — replace with deployed address once provided
TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# ── Filled in after running Setup.s.sol ───────────────────────────────────────
VAULT_ADDRESS=

# ── Filled in after running CreateAgreement.s.sol ─────────────────────────────
AGREEMENT_ADDRESS=

# ── The asset recovery address from your agreement (receives returned funds) ──
# Set this to the deployer address you used in CreateAgreement.s.sol
RECOVERY_ADDRESS=
